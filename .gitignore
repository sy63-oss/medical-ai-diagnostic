# ── Secrets (NEVER commit) ────────────────────────────────────
.env
*.pem
*.key
kubeconfig.yaml

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/

# ── Data (managed by DVC) ─────────────────────────────────────
data/
!data/.gitkeep

