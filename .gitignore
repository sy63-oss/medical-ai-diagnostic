mlops/mlflow/
*.h5
*.pb
saved_model/

# ── Test & coverage outputs ───────────────────────────────────
.coverage
coverage.xml
test-results.xml
htmlcov/
.pytest_cache/

# ── IDE ───────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
.DS_Store
