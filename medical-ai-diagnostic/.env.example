# Medical AI Diagnostic — Environment Variables Template
# Copy to .env and replace all CHANGE_ME values before starting services.
#
# Generate secrets with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"

# ── Security ──────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_generate_with_secrets_token_urlsafe
CONSENT_SECRET=CHANGE_ME_generate_with_secrets_token_urlsafe
AUDIT_SALT=CHANGE_ME_generate_with_secrets_token_urlsafe

# ── Database ──────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=medical_audit
DB_USER=apiuser
DB_PASSWORD=CHANGE_ME

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME

# ── MLflow ────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_DB_PASSWORD=CHANGE_ME

# ── Monitoring ────────────────────────────────────────────────
GRAFANA_PASSWORD=CHANGE_ME

# ── Application ───────────────────────────────────────────────
ENV=development
MODEL_VERSION=v2.1.0

# Path to TF SavedModel directory loaded at API startup.
# Leave empty in development to use stub inference (no model required).
MODEL_PATH=

# ── CORS ──────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000
